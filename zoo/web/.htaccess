Options -Indexes

<FilesMatch "\.(inc|sql|xml|ini|yml|log|md|env)$">
    Require all denied
</FilesMatch>

ErrorDocument 403 /public_html/errors/403.php
ErrorDocument 404 /public_html/errors/404.php
ErrorDocument 500 /public_html/errors/500.php

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
